generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Dish {
  id              String           @id
  name            String
  description     String?
  sourceType      String           @default("manual")
  status          String           @default("published")
  /// 菜谱维度点赞（应用内），与关联视频点赞合并为对外 likeCount
  dishLikeCount   Int              @default(0)
  cookTimeMinutes Int?
  difficulty      Int?
  tasteTags       Json             @default("[]")
  stepsSummary    Json             @default("[]")
  aiResults       AiGenerationResult[]
  ingredients     DishIngredient[]
  videos          Video[]
  videoRequest    VideoRequestDemand?
  favorites       UserFavorite[]
  viewHistories   UserHistory[]
  dishLikes       UserDishLike[]
}

model Ingredient {
  id          String           @id
  name        String           @unique
  aliasNames  Json             @default("[]")
  category    String?
  dishLinks   DishIngredient[]
}

model DishIngredient {
  id           String      @id
  dishId       String
  ingredientId String
  role         String
  amountText   String?
  dish         Dish        @relation(fields: [dishId], references: [id])
  ingredient   Ingredient  @relation(fields: [ingredientId], references: [id])
}

model Video {
  id            String   @id
  dishId         String
  sourcePlatform String
  sourceVideoId  String
  title          String
  url            String
  durationSec    Int?
  likeCount      Int?
  dish           Dish     @relation(fields: [dishId], references: [id])
}

model UserFavorite {
  id         String   @id @default(cuid())
  userId     String
  dishId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  dish       Dish     @relation(fields: [dishId], references: [id])

  @@unique([userId, dishId])
  @@index([userId, createdAt])
}

model UserHistory {
  id         String   @id @default(cuid())
  userId     String
  dishId     String
  viewedAt   DateTime @default(now()) @updatedAt
  dish       Dish     @relation(fields: [dishId], references: [id])

  @@index([userId, viewedAt])
  @@unique([userId, dishId])
}

model UserDishLike {
  id        String   @id @default(cuid())
  userId    String
  dishId    String
  createdAt DateTime @default(now())
  dish      Dish     @relation(fields: [dishId], references: [id], onDelete: Cascade)

  @@unique([userId, dishId])
  @@index([userId, createdAt])
}

model AuthSmsCode {
  id          String   @id @default(cuid())
  phone       String
  code        String
  expiredAt   DateTime
  verifiedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([phone, createdAt])
}

model AuthSession {
  id                String   @id @default(cuid())
  userId            String
  phone             String
  accessToken       String   @unique
  refreshToken      String   @unique
  accessExpiredAt   DateTime
  refreshExpiredAt  DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model VideoRequestDemand {
  dishId               String   @id
  totalRequests        Int      @default(0)
  uniqueRequestUsers   Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  dish                 Dish     @relation(fields: [dishId], references: [id])
}

model VideoRequestRecord {
  id               String   @id @default(cuid())
  dishId           String
  requesterKey     String
  firstRequestedAt DateTime @default(now())
  lastRequestedAt  DateTime @default(now())
  requestCount     Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([dishId, requesterKey])
  @@index([dishId, lastRequestedAt])
}

model AiGenerationTask {
  id               String   @id @default(cuid())
  sceneType        String
  normalizedQuery  String
  queryHash        String
  status           String   @default("pending")
  model            String?
  latencyMs        Int?
  errorCode        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  results          AiGenerationResult[]

  @@unique([sceneType, queryHash])
  @@index([sceneType, status, createdAt])
}

model AiGenerationResult {
  id               String           @id @default(cuid())
  taskId           String
  dishId           String
  score            Float?
  validationResult String?
  rawJson          Json?
  createdAt        DateTime         @default(now())
  task             AiGenerationTask @relation(fields: [taskId], references: [id])
  dish             Dish             @relation(fields: [dishId], references: [id])

  @@unique([taskId, dishId])
}

// --- BigChef V2: 社区、家庭、临时聚餐 ---

model CommunityMediaAsset {
  id                 String          @id @default(cuid())
  ownerId            String
  originFileName     String?
  originMime         String?
  originSize         Int?
  storageKeyRaw      String?
  storageKeyPlayback String?
  coverKey           String?
  transcodeStatus    String          @default("pending")
  errorCode          String?
  durationSec        Int?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  post               CommunityPost?
}

model CommunityPost {
  id               String                 @id @default(cuid())
  authorId         String
  title            String?
  content          String?
  dishId           String?
  tags             Json                   @default("[]")
  assetId          String?                @unique
  videoUrl         String?
  coverUrl         String?
  videoStatus      String?
  durationSec      Int?
  status           String                 @default("published")
  likeCount        Int                    @default(0)
  commentCount     Int                    @default(0)
  favoriteCount    Int                    @default(0)
  completePlayRate Float                  @default(0)
  playSamples      Int                    @default(0)
  moderationStatus String                 @default("ok")
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  asset            CommunityMediaAsset?   @relation(fields: [assetId], references: [id])
  comments         CommunityComment[]
  likes            CommunityPostLike[]
  favorites        CommunityPostFavorite[]
  reports          CommunityPostReport[]

  @@index([authorId, createdAt])
  @@index([status, createdAt])
}

model CommunityPostReport {
  id         String        @id @default(cuid())
  postId     String
  reporterId String
  reason     String
  createdAt  DateTime      @default(now())
  post       CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, reporterId])
  @@index([postId, createdAt])
}

model CommunityComment {
  id        String        @id @default(cuid())
  postId    String
  authorId  String
  content   String
  createdAt DateTime      @default(now())
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
}

model CommunityPostLike {
  id        String        @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime      @default(now())
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId, createdAt])
}

model CommunityPostFavorite {
  id        String        @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime      @default(now())
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId, createdAt])
}

model Family {
  id                  String             @id @default(cuid())
  name                String
  ownerId             String
  inviteCode          String             @unique
  householdRelation   String
  collaborationMode   String             @default("couple_flexible")
  hostOnlyEdit        Boolean            @default(false)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  members             FamilyMember[]
  menuWeeks           FamilyMenuWeek[]
  wishes              FamilyDishWish[]
  shoppingLists       FamilyShoppingList[]
  checkins            FamilyCheckin[]
}

model FamilyCheckin {
  id         String   @id @default(cuid())
  familyId   String
  userId     String
  dishId     String?
  menuWeekId String?
  content    String?
  mediaUrl   String?
  createdAt  DateTime @default(now())
  family     Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([familyId, createdAt])
  @@index([userId, createdAt])
}

model FamilyMember {
  id        String   @id @default(cuid())
  familyId  String
  userId    String
  role      String   @default("member")
  createdAt DateTime @default(now())
  family    Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@unique([familyId, userId])
  @@index([userId])
}

model FamilyMenuWeek {
  id              String               @id @default(cuid())
  familyId        String
  weekStart       DateTime
  status          String               @default("active")
  lastGeneratedAt DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  family          Family               @relation(fields: [familyId], references: [id], onDelete: Cascade)
  mealPlans       FamilyMealPlan[]
  shoppingLists   FamilyShoppingList[]

  @@unique([familyId, weekStart])
}

model FamilyMealPlan {
  id               String         @id @default(cuid())
  familyId         String
  menuWeekId       String
  dishId           String
  /// 前端自由文本菜名（当 dishId 为占位或自定义时使用）
  dishName         String?
  /// 对应星期几的标识（如 "mon","tue"…）
  weekday          String?
  /// 对应餐次标识（如 "breakfast","lunch","dinner"）
  mealKind         String?
  date             DateTime
  assigneeUserId   String?
  status           String         @default("planned")
  createdAt        DateTime       @default(now())
  menuWeek         FamilyMenuWeek @relation(fields: [menuWeekId], references: [id], onDelete: Cascade)

  @@index([menuWeekId])
  @@index([familyId, date])
}

model FamilyDishWish {
  id        String   @id @default(cuid())
  familyId  String
  userId    String
  dishId    String
  note      String?
  status    String   @default("active")
  /// 心愿关联到周菜单的星期（如 "mon"）
  linkedDay String?
  /// 心愿关联到周菜单的餐次（如 "lunch"）
  linkedMeal String?
  createdAt DateTime @default(now())
  family    Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([familyId, status])
}

model FamilyShoppingList {
  id         String                   @id @default(cuid())
  familyId   String
  menuWeekId String?
  mode       String                   @default("single")
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt
  family     Family                   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  menuWeek   FamilyMenuWeek?          @relation(fields: [menuWeekId], references: [id], onDelete: SetNull)
  items      FamilyShoppingListItem[]
}

model FamilyShoppingListItem {
  id                    String             @id @default(cuid())
  listId                String
  ingredientKey         String
  displayName           String
  quantity              String?
  unit                  String?
  category              String?
  batchIndex            Int?
  suggestedPurchaseDate DateTime?
  excludedReason        String?
  purchasedAt           DateTime?
  purchasedByUserId     String?
  sortOrder             Int                @default(0)
  list                  FamilyShoppingList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@index([listId, sortOrder])
}

model Gathering {
  id                         String             @id @default(cuid())
  creatorId                  String
  title                      String?
  headcount                  Int
  status                     String             @default("collecting")
  shareToken                 String             @unique
  expiresAt                  DateTime?
  menuItems                  Json?
  shoppingList               Json?
  beveragePresets            Json               @default("[]")
  beverageNote               String?
  includeBeverageInShopping  Boolean            @default(false)
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime           @updatedAt
  members                    GatheringMember[]
  wishes                     GatheringWish[]
}

model GatheringMember {
  id          String    @id @default(cuid())
  gatheringId String
  userId      String
  joinedAt    DateTime  @default(now())
  gathering   Gathering @relation(fields: [gatheringId], references: [id], onDelete: Cascade)

  @@unique([gatheringId, userId])
  @@index([userId])
}

model GatheringWish {
  id          String    @id @default(cuid())
  gatheringId String
  userId      String
  dishId      String?
  freeText    String?
  createdAt   DateTime  @default(now())
  gathering   Gathering @relation(fields: [gatheringId], references: [id], onDelete: Cascade)

  @@index([gatheringId, createdAt])
}
