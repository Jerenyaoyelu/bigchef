generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Dish {
  id              String           @id
  name            String
  description     String?
  sourceType      String           @default("manual")
  status          String           @default("published")
  /// 菜谱维度点赞（应用内），与关联视频点赞合并为对外 likeCount
  dishLikeCount   Int              @default(0)
  cookTimeMinutes Int?
  difficulty      Int?
  tasteTags       Json             @default("[]")
  stepsSummary    Json             @default("[]")
  aiResults       AiGenerationResult[]
  ingredients     DishIngredient[]
  videos          Video[]
  videoRequest    VideoRequestDemand?
  favorites       UserFavorite[]
  viewHistories   UserHistory[]
  dishLikes       UserDishLike[]
}

model Ingredient {
  id          String           @id
  name        String           @unique
  aliasNames  Json             @default("[]")
  category    String?
  dishLinks   DishIngredient[]
}

model DishIngredient {
  id           String      @id
  dishId       String
  ingredientId String
  role         String
  amountText   String?
  dish         Dish        @relation(fields: [dishId], references: [id])
  ingredient   Ingredient  @relation(fields: [ingredientId], references: [id])
}

model Video {
  id            String   @id
  dishId         String
  sourcePlatform String
  sourceVideoId  String
  title          String
  url            String
  durationSec    Int?
  likeCount      Int?
  dish           Dish     @relation(fields: [dishId], references: [id])
}

model UserFavorite {
  id         String   @id @default(cuid())
  userId     String
  dishId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  dish       Dish     @relation(fields: [dishId], references: [id])

  @@unique([userId, dishId])
  @@index([userId, createdAt])
}

model UserHistory {
  id         String   @id @default(cuid())
  userId     String
  dishId     String
  viewedAt   DateTime @default(now()) @updatedAt
  dish       Dish     @relation(fields: [dishId], references: [id])

  @@index([userId, viewedAt])
  @@unique([userId, dishId])
}

model UserDishLike {
  id        String   @id @default(cuid())
  userId    String
  dishId    String
  createdAt DateTime @default(now())
  dish      Dish     @relation(fields: [dishId], references: [id], onDelete: Cascade)

  @@unique([userId, dishId])
  @@index([userId, createdAt])
}

model AuthSmsCode {
  id          String   @id @default(cuid())
  phone       String
  code        String
  expiredAt   DateTime
  verifiedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([phone, createdAt])
}

model AuthSession {
  id                String   @id @default(cuid())
  userId            String
  phone             String
  accessToken       String   @unique
  refreshToken      String   @unique
  accessExpiredAt   DateTime
  refreshExpiredAt  DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model VideoRequestDemand {
  dishId               String   @id
  totalRequests        Int      @default(0)
  uniqueRequestUsers   Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  dish                 Dish     @relation(fields: [dishId], references: [id])
}

model VideoRequestRecord {
  id               String   @id @default(cuid())
  dishId           String
  requesterKey     String
  firstRequestedAt DateTime @default(now())
  lastRequestedAt  DateTime @default(now())
  requestCount     Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([dishId, requesterKey])
  @@index([dishId, lastRequestedAt])
}

model AiGenerationTask {
  id               String   @id @default(cuid())
  sceneType        String
  normalizedQuery  String
  queryHash        String
  status           String   @default("pending")
  model            String?
  latencyMs        Int?
  errorCode        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  results          AiGenerationResult[]

  @@unique([sceneType, queryHash])
  @@index([sceneType, status, createdAt])
}

model AiGenerationResult {
  id               String           @id @default(cuid())
  taskId           String
  dishId           String
  score            Float?
  validationResult String?
  rawJson          Json?
  createdAt        DateTime         @default(now())
  task             AiGenerationTask @relation(fields: [taskId], references: [id])
  dish             Dish             @relation(fields: [dishId], references: [id])

  @@unique([taskId, dishId])
}
